{
    "name": "@crawlee/storage",
    "version": "0.1.0",
    "description": "Filesystem storage client for Crawlee crawlers (Rust-powered)",
    "license": "Apache-2.0",
    "main": "index.js",
    "types": "index.d.ts",
    "scripts": {
        "artifacts": "napi artifacts",
        "build": "napi build --platform --release --no-const-enum",
        "build:debug": "napi build --platform --no-const-enum",
        "test": "vitest run",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check"
    },
    "devDependencies": {
        "@napi-rs/cli": "^3",
        "@types/node": "^22",
        "oxfmt": "^0.44.0",
        "oxlint": "^1.59.0",
        "oxlint-tsgolint": "^0.20.0",
        "typescript": "^5",
        "vitest": "^3"
    },
    "napi": {
        "binaryName": "crawlee-storage",
        "dtsHeaderFile": "dts-header.d.ts",
        "targets": [
            "x86_64-unknown-linux-gnu",
            "x86_64-apple-darwin",
            "aarch64-apple-darwin",
            "x86_64-pc-windows-msvc"
        ]
    }
}
